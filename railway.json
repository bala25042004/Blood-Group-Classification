{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "python": {
      "version": "3.11"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restart": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "web": {
      "command": "gunicorn --bind 0.0.0.0:$PORT app:app",
      "healthcheckPath": "/",
      "healthcheckTimeout": 60
    }
  }
}
